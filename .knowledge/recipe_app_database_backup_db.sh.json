{"is_source_file": true, "format": "bash", "description": "Universal Database Backup Script that detects and backs up SQLite, PostgreSQL, MySQL, and MongoDB databases based on the environment and availability.", "external_files": ["/usr/lib/postgresql/", "/var/run/mysqld/mysqld.sock"], "external_methods": ["ls", "cp", "sudo -u postgres pg_isready", "pg_dump", "mysqladmin", "mysql", "mysqldump", "mongosh", "mongodump"], "published": [], "classes": [], "methods": [], "calls": ["ls /usr/lib/postgresql/", "cp \"${DB_NAME}\" \"database_backup.db\"", "sudo -u postgres ${PG_BIN}/pg_isready -p ${DB_PORT}", "pg_dump -h localhost -p ${DB_PORT} -U ${DB_USER} -d ${DB_NAME} --clean --if-exists --create", "mysqladmin ping -h localhost -P ${DB_PORT} --silent", "sudo mysqladmin ping --socket=/var/run/mysqld/mysqld.sock --silent", "mysql -h localhost -P ${DB_PORT} -u ${DB_USER} -p${DB_PASSWORD} -e \"SELECT 1\"", "mysqldump -h localhost -P ${DB_PORT} -u ${DB_USER} -p${DB_PASSWORD} --databases ${DB_NAME} --add-drop-database --routines --triggers --single-transaction", "mysql -h localhost -P ${DB_PORT} -u root -p${DB_PASSWORD} -e \"SELECT 1\"", "mysqldump -h localhost -P ${DB_PORT} -u root -p${DB_PASSWORD} --databases ${DB_NAME} --add-drop-database --routines --triggers --single-transaction", "sudo mysql --socket=/var/run/mysqld/mysqld.sock -u root -p${DB_PASSWORD} -e \"SELECT 1\"", "sudo mysqldump --socket=/var/run/mysqld/mysqld.sock -u root -p${DB_PASSWORD} --databases ${DB_NAME} --add-drop-database --routines --triggers --single-transaction", "mongosh --port ${DB_PORT} --eval \"db.adminCommand('ping')\"", "mongodump --port ${DB_PORT} --db ${DB_NAME} --archive=database_backup.archive --quiet"], "search-terms": ["backup_db.sh", "database backup", "SQLite", "PostgreSQL", "MySQL", "MongoDB", "Database detection", "data dump", "shell script"], "state": 2, "file_id": 6, "knowledge_revision": 14, "git_revision": "2d7d5063bdfb2bc32220a323de5dd52cbd514867", "hash": "7af9aa35fa4940f934d83f6e2